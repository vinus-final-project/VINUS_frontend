<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- API 가 https(api.voice-in-us.com)로 전환됨 — cleartext 불필요 -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- 결제 복귀 딥링크: backend /payments/toss/return 응답 페이지가
                 voiceinus://payment-{success|fail} 로 앱을 전면 복귀시킨다 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="voiceinus" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- 결제 앱 패키지 가시성 (Android 11+) — 토스 결제창이 intent:// 로
         호출하는 간편결제/앱카드 앱을 startActivity 로 열 수 있게 등록.
         (MainActivity.handlePaymentScheme 와 세트) -->
    <queries>
        <package android:name="com.kakao.talk" />                <!-- 카카오톡(카카오페이) -->
        <package android:name="com.kakaopay.app" />              <!-- 카카오페이 -->
        <package android:name="viva.republica.toss" />           <!-- 토스 -->
        <package android:name="com.nhnent.payapp" />             <!-- 페이코 -->
        <package android:name="com.samsung.android.spay" />      <!-- 삼성페이 -->
        <package android:name="kvp.jjy.MispAndroid320" />        <!-- ISP/페이북 -->
        <package android:name="com.shcard.smartpay" />           <!-- 신한 -->
        <package android:name="com.kbcard.cxh.appcard" />        <!-- KB -->
        <package android:name="com.hyundaicard.appcard" />       <!-- 현대 -->
        <package android:name="kr.co.samsungcard.mpocket" />     <!-- 삼성카드 -->
        <package android:name="com.lcacApp" />                   <!-- 롯데 -->
        <package android:name="com.hanaskcard.paycla" />         <!-- 하나 -->
        <package android:name="com.wooricard.smartapp" />        <!-- 우리 -->
        <package android:name="nh.smart.nhallonepay" />          <!-- NH -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="intent" />
        </intent>
    </queries>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 음성 주문 — WebView getUserMedia(마이크) 용.
         Capacitor Bridge 가 페이지의 마이크 요청 시 런타임 권한을 요청한다. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- 영수증 프린터 — USB 호스트 모드 (태블릿에 USB 프린터 직결) -->
    <uses-feature android:name="android.hardware.usb.host" />
</manifest>
